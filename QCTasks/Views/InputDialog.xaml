<local:DialogBase x:Class="QCTasks.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QCTasks.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:lib="clr-namespace:libeLog;assembly=libeLog"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" AllowsTransparency="True"
        SizeToContent="WidthAndHeight"
        MinWidth="400"
        MaxWidth="520"
        FontFamily="Segoe UI">

    <local:DialogBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Style/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </local:DialogBase.Resources>

    <Border Background="#F0F2F5" CornerRadius="6"
        BorderBrush="{x:Static lib:Constants+Colors.AreopagBlue}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    x:Name="HeaderBorder"
                    Background="{x:Static lib:Constants+Colors.AreopagBlue}"
                    CornerRadius="6 6 0 0" Margin="-1"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="20,14"/>
                    <Button Style="{StaticResource DialogCloseButton}"
                            HorizontalAlignment="Right"
                            Click="Cancel_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="28,24,28,20">
                <TextBlock x:Name="MessageText"
                           FontSize="15"
                           Foreground="#212121"
                           TextWrapping="Wrap"
                           LineHeight="24"/>

                <TextBlock x:Name="DetailText"
                           FontSize="13"
                           Foreground="#757575"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Visibility="Collapsed"/>

                <TextBox x:Name="InputTextBox"
                         Margin="0,16,0,0"
                         MinWidth="320"
                         Padding="12,10"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         PreviewKeyDown="InputTextBox_PreviewKeyDown"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="28,0,28,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelButton"
                        Grid.Column="0"
                        Style="{StaticResource SecondaryButton}"
                        Padding="0,14"
                        Click="Cancel_Click"/>

                <Button x:Name="OkButton"
                        Grid.Column="2"
                        Style="{StaticResource PrimaryButton}"
                        Padding="28,14"
                        Click="Ok_Click"/>
            </Grid>
        </Grid>
    </Border>
</local:DialogBase>