<Window x:Class="QCTasks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:QCTasks"
        xmlns:cnv="clr-namespace:QCTasks.Converters"
        xmlns:vm="clr-namespace:QCTasks.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Контроль ОТК" Height="760" Width="1200"
        MinWidth="860" MinHeight="520"
        Background="#F0F2F5"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter         x:Key="BoolToVis"/>
        <cnv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <cnv:StringToVisibilityConverter      x:Key="StringToVis"/>
        <cnv:StatusToAccentBrushConverter     x:Key="StatusToAccent"/>
        <cnv:StatusToForegroundConverter      x:Key="StatusToFg"/>
        <cnv:StatusToBackgroundConverter      x:Key="StatusToBg"/>
        <cnv:IsInWorkToVisibilityConverter    x:Key="IsInWorkToVis"/>
        <cnv:IsNotInWorkToVisibilityConverter x:Key="IsNotInWorkToVis"/>

        <ControlTemplate x:Key="PillButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="WinCtrlTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#283593"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#1A2272"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="WinCloseTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#C62828"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#B71C1C"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template"        Value="{StaticResource PillButtonTemplate}"/>
        </Style>

        <!-- "В работу" — синяя -->
        <Style x:Key="BtnStartWork" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#283593"/>
            <Setter Property="Padding"    Value="20,11"/>
            <Setter Property="FontSize"   Value="14"/>
        </Style>

        <!-- "Завершить" — зелёная -->
        <Style x:Key="BtnComplete" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Padding"    Value="20,11"/>
            <Setter Property="FontSize"   Value="14"/>
        </Style>

        <Style x:Key="BtnChangeStatus" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Padding"    Value="16,9"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <Style x:Key="BtnHeader" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#283593"/>
            <Setter Property="Padding"    Value="18,9"/>
            <Setter Property="FontSize"   Value="14"/>
        </Style>

        <DropShadowEffect x:Key="CardShadow"     Color="#000" Opacity="0.08" BlurRadius="10" ShadowDepth="2" Direction="270"/>
        <DropShadowEffect x:Key="CardShadowFaint" Color="#000" Opacity="0.04" BlurRadius="6"  ShadowDepth="1" Direction="270"/>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ ШАПКА ══ -->
        <Border Grid.Row="0" Background="#1A237E" Padding="20,0,0,0"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,14,16,14">
                    <TextBlock Text="Контроль ОТК"
                               Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="  •  Обновление..."
                               Foreground="#90CAF9" FontSize="13" VerticalAlignment="Center"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding StatusMessage, StringFormat='  •  {0}'}"
                               Foreground="#5C6BC0" FontSize="12" VerticalAlignment="Center"
                               Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="⚙" FontSize="18" FontWeight="ExtraLight"
                        Style="{StaticResource BtnHeader}" Padding="14 9 14 9"
                        Command="{Binding OpenSettingsCommand}"
                        Margin="0,10,6,10"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Button Grid.Column="2" Content="↻  Обновить"
                        Style="{StaticResource BtnHeader}"
                        Command="{Binding RefreshCommand}"
                        Margin="0,10,8,10"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Rectangle Grid.Column="3" Width="1" Fill="#283593" Margin="0,8"/>

                <Button Grid.Column="4" Width="58" Height="58" Content="—"
                        FontSize="18" Foreground="#90CAF9" Background="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        Click="MinimizeButton_Click"
                        Template="{StaticResource WinCtrlTemplate}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Button Grid.Column="5" Width="58" Height="58" Content="⬜"
                        FontSize="15" Foreground="#90CAF9" Background="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        Click="MaximizeButton_Click"
                        Template="{StaticResource WinCtrlTemplate}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Button Grid.Column="6" Width="68" Height="58" Content="✕"
                        FontSize="18" Foreground="#EF9A9A" Background="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        Click="CloseButton_Click"
                        Template="{StaticResource WinCloseTemplate}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>
        </Border>

        <!-- ══ КОНТЕНТ ══ -->
        <Grid Grid.Row="1" Margin="16,14,16,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto" MaxHeight="300"/>
            </Grid.RowDefinitions>

            <!-- Баннер "не настроено" -->
            <Border Grid.Row="0" Grid.RowSpan="2" Background="#F0F2F5"
                    Visibility="{Binding IsNotConfigured, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="10">
                <Border Background="White" CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="48,40" MinWidth="440">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="68" Height="68" CornerRadius="34"
                                Background="#FFF8E1" HorizontalAlignment="Center"
                                Margin="0,0,0,18">
                            <TextBlock Text="⚙" FontSize="32" FontWeight="ExtraLight" Padding="0 0 0 4.5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#F9A825"/>
                        </Border>
                        <TextBlock Text="Требуется настройка"
                                   FontSize="19" FontWeight="Bold" Foreground="#1A237E"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <Border Background="#FFF8E1" CornerRadius="8"
                                Padding="16,12" Margin="0,0,0,24" MaxWidth="360">
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#E65100" FontSize="13"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </Border>
                        <Button Content="Открыть настройки"
                                HorizontalAlignment="Center"
                                Style="{StaticResource BtnHeader}"
                                Padding="32,14" FontSize="15"
                                Command="{Binding OpenSettingsCommand}"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Текущие задачи -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Текущие задачи"
                               FontSize="15" FontWeight="SemiBold" Foreground="#1A237E"
                               VerticalAlignment="Center"/>
                    <Border Background="#E3F2FD" CornerRadius="10" Padding="8,2"
                            Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Tasks.Count}"
                                   Foreground="#1565C0" FontSize="13" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadowFaint}"
                        Visibility="{Binding IsTasksEmpty, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="✓" FontSize="52" Foreground="#A5D6A7"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Нет активных задач" FontSize="16"
                                   Foreground="#9E9E9E" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsTasksEmpty, Converter={StaticResource InvBoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" CornerRadius="9" Background="White"
                                        Effect="{StaticResource CardShadow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Полоса: синяя в ожидании, чуть ярче когда в работе -->
                                        <Border Grid.Column="0"
                                                Background="{Binding EngeneersComment, Converter={StaticResource StatusToAccent}}"
                                                CornerRadius="9,0,0,9"/>

                                        <StackPanel Grid.Column="1" Margin="10,5,5,5">
                                            <StackPanel Orientation="Horizontal">
                                                <Border HorizontalAlignment="Left"
                                                        Background="#FFEBEE" CornerRadius="5"
                                                        Width="50" Margin="0,0,6,6"
                                                        Visibility="{Binding Priority, Converter={StaticResource StringToVis}}">
                                                    <TextBlock Text="{Binding Priority}"
                                                               Foreground="#E65100"
                                                               TextAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="12"/>
                                                </Border>
                                                <TextBlock Text="{Binding PartName}"
                                                           FontSize="17" FontWeight="Bold"
                                                           Foreground="#1A237E" TextWrapping="Wrap"
                                                           Margin="0,0,0,8"/>
                                            </StackPanel>

                                            <WrapPanel Margin="0,0,0,6">
                                                <Border Background="#E3F2FD" CornerRadius="5"
                                                        Width="150" Height="24" Margin="0,0,8,0"
                                                        Visibility="{Binding Order, Converter={StaticResource StringToVis}}">
                                                    <TextBlock FontSize="13" Foreground="#1565C0"
                                                               TextAlignment="Center" VerticalAlignment="Center">
                                                        <Run Text="М/Л: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding Order}"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#E3F2FD" CornerRadius="5"
                                                        Width="150" Height="24" Margin="0,0,8,0"
                                                        Visibility="{Binding PartsCount, Converter={StaticResource StringToVis}}">
                                                    <TextBlock FontSize="13" Foreground="#1565C0"
                                                               TextAlignment="Center" VerticalAlignment="Center">
                                                        <Run Text="Количество: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding PartsCount}"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#E3F2FD" CornerRadius="5"
                                                        Width="150" Height="24"
                                                        Visibility="{Binding Date, Converter={StaticResource StringToVis}}">
                                                    <TextBlock FontSize="13" Foreground="#1565C0"
                                                               TextAlignment="Center" VerticalAlignment="Center">
                                                        <Run Text="Дата: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding Date}"/>
                                                    </TextBlock>
                                                </Border>
                                            </WrapPanel>

                                            <TextBlock FontSize="13" Foreground="#424242" TextWrapping="Wrap"
                                                       Visibility="{Binding PlantComment, Converter={StaticResource StringToVis}}">
                                                <Run Text="Комментарий: " Foreground="#757575"/>
                                                <Run Text="{Binding PlantComment}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Кнопки: одна из двух видима в зависимости от статуса -->
                                        <Border Grid.Column="2" Padding="0,14,18,14" VerticalAlignment="Center">
                                            <StackPanel>
                                                <!-- "В работу" — видна когда статус НЕ "В работе" -->
                                                <Button Content="В работу"
                                                        Width="136"
                                                        Style="{StaticResource BtnStartWork}"
                                                        Visibility="{Binding EngeneersComment,
                                                            Converter={StaticResource IsNotInWorkToVis}}"
                                                        Command="{Binding DataContext.StartWorkCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <!-- "Завершить" — видна только когда "В работе" -->
                                                <Button Content="Завершить"
                                                        Width="136"
                                                        Style="{StaticResource BtnComplete}"
                                                        Visibility="{Binding EngeneersComment,
                                                            Converter={StaticResource IsInWorkToVis}}"
                                                        Command="{Binding DataContext.CompleteCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Завершённые задачи -->
            <Grid Grid.Row="1"
                  Visibility="{Binding HasCompletedTasks, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Завершённые"
                               FontSize="14" FontWeight="SemiBold" Foreground="#616161"
                               VerticalAlignment="Center"/>
                    <Border Background="#EEEEEE" CornerRadius="10" Padding="8,2"
                            Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CompletedTasks.Count}"
                                   Foreground="#757575" FontSize="13" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CompletedTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,7" CornerRadius="9" Background="#FAFAFA"
                                        Effect="{StaticResource CardShadowFaint}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{Binding EngeneersComment, Converter={StaticResource StatusToAccent}}"
                                                CornerRadius="9,0,0,9"/>

                                        <Grid Grid.Column="1" Margin="18,11,14,11">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PartName}"
                                                           FontSize="15" FontWeight="SemiBold"
                                                           Foreground="#616161" TextWrapping="Wrap"
                                                           Margin="0,0,0,5"/>
                                                <WrapPanel>
                                                    <TextBlock FontSize="12" Foreground="#9E9E9E" Margin="0,0,14,0"
                                                               Visibility="{Binding Order, Converter={StaticResource StringToVis}}"
                                                               Text="{Binding Order}"/>
                                                    <TextBlock FontSize="12" Foreground="#9E9E9E" Margin="0,0,14,0"
                                                               Visibility="{Binding Date, Converter={StaticResource StringToVis}}"
                                                               Text="{Binding Date}"/>
                                                    <TextBlock FontSize="12" Foreground="#9E9E9E"
                                                               Visibility="{Binding PartsCount, Converter={StaticResource StringToVis}}"
                                                               Text="{Binding PartsCount}"/>
                                                </WrapPanel>
                                            </StackPanel>

                                            <Border Grid.Column="1" CornerRadius="5" Padding="12,4"
                                                    VerticalAlignment="Center" Margin="10,0,0,0"
                                                    Background="{Binding EngeneersComment, Converter={StaticResource StatusToBg}}">
                                                <TextBlock Text="{Binding EngeneersComment}"
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="{Binding EngeneersComment, Converter={StaticResource StatusToFg}}"/>
                                            </Border>
                                        </Grid>

                                        <Border Grid.Column="2" Padding="0,11,18,11" VerticalAlignment="Center">
                                            <Button Content="Изменить статус" Width="155"
                                                    Style="{StaticResource BtnChangeStatus}"
                                                    Command="{Binding DataContext.ChangeStatusCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
