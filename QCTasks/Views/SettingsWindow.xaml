<local:DialogBase x:Class="QCTasks.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QCTasks.Views"
        xmlns:vm="clr-namespace:QCTasks.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
        Title="Настройки" Width="560" SizeToContent="Height"
        FontFamily="Segoe UI" Background="#F0F2F5">

    <local:DialogBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Style/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </local:DialogBase.Resources>

    <Border Background="#F0F2F5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Шапка -->
                <RowDefinition Height="*"/>
                <!-- Контент -->
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Background="#1A237E"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="20,14">
                        <TextBlock Text="Настройки"
                                   Foreground="White"
                                   FontSize="17" FontWeight="Bold"/>
                    </StackPanel>
                    <Button Style="{StaticResource DialogCloseButton}"
                            HorizontalAlignment="Right"
                            Command="{Binding CancelCommand}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Форма -->
            <StackPanel Grid.Row="1" Margin="28,24,28,28">

                <!-- Google Credentials -->
                <TextBlock Text="Файл учётных данных Google (JSON)"
                           Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Style="{StaticResource DialogTextBox}"
                             Text="{Binding CredentialsFile, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"/>
                    <Button Grid.Column="1"
                            Content="Обзор..."
                            Style="{StaticResource SecondaryButton}"
                            Padding="18,0"
                            Height="{Binding ActualHeight,
                                    RelativeSource={RelativeSource PreviousData}}"
                            Margin="8,0,0,0"
                            Command="{Binding BrowseCredentialsCommand}"/>
                </Grid>

                <!-- Sheet ID -->
                <TextBlock Text="ID таблицы Google Sheets"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource DialogTextBox}"
                         Text="{Binding SheetId, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,18"/>

                <!-- SQL Connection String -->
                <TextBlock Text="Строка подключения SQL Server"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource DialogTextBox}"
                         Text="{Binding SqlConnectionString, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,6"
                         AcceptsReturn="False"/>
                <TextBlock Text="Пример: Server=SRV\SQLEXPRESS;Database=Production;Integrated Security=True"
                           FontSize="11" Foreground="#9E9E9E" Margin="0,0,0,24"/>

                <!-- Ошибка -->
                <Border Background="#FFEBEE" CornerRadius="6" Padding="14,10"
                        Margin="0,0,0,18"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#C62828" FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Кнопки -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               FontSize="11" Foreground="#BDBDBD"
                               Text="{Binding ConfigPath,
                                      StringFormat='Конфиг: {0}'}"/>
                    <Button Grid.Column="1"
                            Content="Отмена"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}"/>
                    <Button Grid.Column="3"
                            Content="Сохранить"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</local:DialogBase>
